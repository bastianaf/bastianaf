---
const skills = [
  "TypeScript", "React", "Node.js", "Go",
  "PostgreSQL", "Docker", "AWS", "GraphQL",
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Section label -->
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400 mb-3">
      About me
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-12">
      A bit about who I am
    </h2>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <!-- Avatar placeholder -->
      <div class="md:col-span-2 flex justify-center md:justify-start">
        <div class="relative">
          <div class="w-48 h-48 rounded-2xl bg-gradient-to-br from-brand-400 to-brand-700 flex items-center justify-center text-white text-6xl font-bold select-none shadow-xl">
            B
          </div>
          <!-- Decorative ring -->
          <div class="absolute -inset-1 rounded-2xl border-2 border-brand-200 dark:border-brand-800 -z-10"></div>
        </div>
      </div>

      <!-- Bio text -->
      <div class="md:col-span-3 space-y-5 text-slate-600 dark:text-slate-400 leading-relaxed">
        <p>
          Hey! I'm Bastian, a software engineer with a passion for building
          things that are both elegant and useful. I love the intersection of
          design and engineering — where a well-crafted API meets a delightful UI.
        </p>
        <p>
          I've spent the last few years working on web applications, developer
          tooling, and distributed systems. I care deeply about code quality,
          developer experience, and shipping products people actually enjoy using.
        </p>
        <p>
          When I'm not coding, you'll find me exploring new coffee spots,
          reading about architecture and systems, or contributing to open source.
        </p>

        <!-- Skills chips -->
        <div class="pt-4">
          <p class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3">
            Technologies I work with
          </p>
          <div class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <span class="px-3 py-1 text-sm rounded-lg bg-brand-50 dark:bg-brand-950 text-brand-700 dark:text-brand-300 border border-brand-100 dark:border-brand-900 font-medium">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
