---
---
<section id="contact" class="py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400 mb-3">
      Contact
    </p>
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-5">
      Let's work together
    </h2>
    <p class="text-slate-500 dark:text-slate-400 max-w-lg mx-auto mb-10 leading-relaxed">
      I'm always open to interesting conversations, collaborations, or new
      opportunities. Feel free to reach out.
    </p>

    <a
      href="mailto:hello@bastianaf.dev"
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-brand-600 hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600 text-white font-semibold text-lg transition-all hover:shadow-xl hover:shadow-brand-500/30 active:scale-95"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
      Say hello
    </a>

    <!-- Social links -->
    <div class="flex items-center justify-center gap-6 mt-10">
      <a
        href="https://github.com/bastianaf"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/bastianaf"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://twitter.com/bastianaf"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter / X"
        class="text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.741l7.73-8.835L1.254 2.25H8.08l4.259 5.632 5.905-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-slate-200 dark:border-slate-800 py-8 px-6 text-center text-sm text-slate-400 dark:text-slate-600">
  <p>Built with <a href="https://astro.build" class="hover:text-brand-500 transition-colors">Astro</a> &amp; <a href="https://tailwindcss.com" class="hover:text-brand-500 transition-colors">Tailwind CSS</a> &mdash; &copy; {new Date().getFullYear()} bastianaf</p>
</footer>
